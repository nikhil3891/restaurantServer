generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  RESTAURANT_OWNER
  BRANCH_MANAGER
  CASHIER
  KITCHEN_STAFF
  DELIVERY_STAFF
  CUSTOMER
}

// ─────────────────────────────────────────────────────────────
// AUTH MODULE
// ─────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  firstName    String
  lastName     String
  role         UserRole @default(CUSTOMER)
  phone        String?
  isActive     Boolean  @default(true)
  restaurantId String?
  branchId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String
  userId    String
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}
